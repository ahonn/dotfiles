{
  "cleanupPeriodDays": 60,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-state waiting"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/english-mode.sh",
            "statusMessage": "Checking English mode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-state working"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-useeffect.sh",
            "statusMessage": "Checking for useEffect violations..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-state waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-state idle"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccclub sync --silent",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ccclub sync --silent",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "expo-app-design@expo-plugins": true,
    "expo-deployment@expo-plugins": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "react-native-best-practices@callstack-agent-skills": true,
    "impeccable@impeccable": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-mermaid-ascii@claude-mermaid-ascii": true,
    "claude-code-wakatime@wakatime": true,
    "codex@openai-codex": true,
    "figma@claude-plugins-official": true,
    "daily-report@session-tools": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "nowledge-community": {
      "source": {
        "source": "github",
        "repo": "nowledge-co/community"
      }
    },
    "claude-seo": {
      "source": {
        "source": "github",
        "repo": "ahonn/claude-seo"
      }
    },
    "claude-mermaid-ascii": {
      "source": {
        "source": "github",
        "repo": "ahonn/claude-mermaid-ascii"
      }
    },
    "wakatime": {
      "source": {
        "source": "git",
        "url": "https://github.com/wakatime/claude-code-wakatime.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "session-tools": {
      "source": {
        "source": "github",
        "repo": "Suto-Michimasa/cc-session-tools"
      }
    }
  },
  "language": "chinese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
